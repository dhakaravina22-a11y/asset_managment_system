<!DOCTYPE html>
<html>
<head>
    <title>Add Description</title>
    <script>
        function saveDescription() {

            var desc = document.getElementById("desc").value;

            if (!desc || desc.trim() === "") {
                alert("Please enter a description.");
                return;
            }

            try {
                // Get form context
                var formContext = parent.Xrm.Page;

                // Set value in description field
                formContext.getAttribute("ravi_description").setValue(desc);

                // Save record
                formContext.data.save();

                alert("Description saved successfully.");

            } catch (e) {
                alert("Error: " + e.message);
            }
        }
    </script>
</head>
<body style="font-family: Segoe UI; padding: 10px;">
    
    <input 
        type="text" 
        id="desc" 
        placeholder="Enter description" 
        style="width: 200px; padding: 5px;" 
    />

    <button onclick="saveDescription()">
        Save Description
    </button>

</body>
</html>
