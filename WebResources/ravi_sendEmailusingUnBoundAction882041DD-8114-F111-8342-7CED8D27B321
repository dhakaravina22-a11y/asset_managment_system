function sendEmailUsingUnboundAction(PrimaryControl) {
    console.log("sendEmailUsingUnboundAction called");

    let formContext = PrimaryControl;
    var reason = prompt("Enter reason here");
    console.log("User entered reason:", reason);

    if (!reason || reason.trim() === "") {
        formContext.ui.setFormNotification("Reason cannot be empty.", "ERROR", "reason_error");
        return;
    }

    var rawId = formContext.data.entity.getId();
    console.log("Raw record ID from form:", rawId);

    if (!rawId) {
        formContext.ui.setFormNotification("Record ID not found.", "ERROR", "recid_error");
        return;
    }

    let recordId = rawId.replace("{", "").replace("}", "");
    console.log("Cleaned GUID record ID:", recordId);

    var request = {
        recordId: recordId,
        reason: reason,
        getMetadata: function () {
            console.log("getMetadata called");
            return {
                boundParameter: null,
                operationType: 0,
                operationName: "ravi_TriggerFlowAction",
                parameterTypes: {
                    "recordId": { typeName: "Edm.String", structuralProperty: 1 },
                    "reason":   { typeName: "Edm.String", structuralProperty: 1 }
                }
            };
        }
    };

    console.log("Executing custom action with request object:", request);

    Xrm.WebApi.online.execute(request).then(
        function (response) {
            console.log("Response from Web API:", response);
            if (response.ok) {
                Xrm.Navigation.openAlertDialog({ text: "Flow triggered successfully." },
                                              { height: 120, width: 260 });
            } else {
                Xrm.Navigation.openAlertDialog({ text: "Error triggering flow." },
                                              { height: 120, width: 260 });
            }
        },
        function (error) {
            console.error("Error in execute() call:", error);
            Xrm.Navigation.openAlertDialog({ text: "Unexpected error: " + error.message },
                                          { height: 120, width: 340 });
        }
    );
}